<%# locals: (import:) %>
<% center_content = import.importing? || (import.pending? && import.extracted_accounts.blank?) || import.failed? || import.complete? %>
<% polling_processing = import.importing? || (import.pending? && import.extracted_accounts.blank?) %>
<% polling_data = polling_processing ? { controller: "page-polling", page_polling_url_value: import_path(import), page_polling_interval_value: 3000 } : {} %>

<%= tag.div class: "#{center_content ? "h-full justify-center" : "min-h-full justify-start py-8 md:py-10"} flex flex-col items-center", data: polling_data do %>
  <div class="space-y-6 max-w-2xl w-full">
    <% if import.importing? || (import.pending? && import.extracted_accounts.blank?) %>
      <div class="mx-auto bg-gray-tint-5 h-8 w-8 rounded-full flex items-center justify-center">
        <%= icon "loader", class: "animate-pulse" %>
      </div>
      <div class="text-center space-y-2">
        <h1 class="font-medium text-primary text-center text-3xl"><%= t("imports.statement_import.processing_title", default: "Processing statement") %></h1>
        <p class="text-sm text-secondary"><%= t("imports.statement_import.processing_description", default: "We are extracting accounts, balances, and transactions for review.") %></p>
      </div>
      <%= render "imports/processing_progress", import: import, mode: :full %>
      <div class="space-y-2 flex flex-col">
        <% if import.respond_to?(:processing_progress_stale?) && import.processing_progress_stale? %>
          <%= button_to t("imports.progress.retry_processing"),
                retry_processing_import_path(import),
                method: :post,
                class: "w-full font-medium text-sm px-3 py-2 rounded-lg text-inverse bg-inverse hover:bg-inverse-hover" %>
        <% end %>
        <%= render DS::Link.new(text: t("imports.pdf_import.check_status", default: "Check status"), href: import_path(import), variant: "primary", full_width: true) %>
        <%= render DS::Link.new(text: t("imports.pdf_import.back_to_imports", default: "Back to imports"), href: imports_path, variant: "secondary", full_width: true) %>
      </div>

    <% elsif import.failed? %>
      <div class="mx-auto bg-destructive/10 h-8 w-8 rounded-full flex items-center justify-center">
        <%= icon "x", class: "text-destructive" %>
      </div>
      <div class="text-center space-y-2">
        <h1 class="font-medium text-primary text-center text-3xl"><%= t("imports.statement_import.failed_title", default: "Statement processing failed") %></h1>
        <% if import.error.present? %>
          <p class="text-sm text-destructive"><%= import.error %></p>
        <% end %>
      </div>
      <% if import.pdf_uploaded? %>
        <%= form_with model: import, url: import_path(import), scope: :statement_import, method: :patch, class: "space-y-3" do |form| %>
          <%= form.password_field :statement_pdf_password, placeholder: t("imports.statement_import.password_placeholder", default: "PDF password"), class: "form-field__input" %>
          <%= form.submit t("imports.statement_import.retry_with_password", default: "Retry with password"), class: "w-full font-medium text-sm px-3 py-2 rounded-lg text-inverse bg-inverse hover:bg-inverse-hover" %>
        <% end %>
      <% end %>
      <%= render DS::Link.new(text: t("imports.pdf_import.try_again", default: "Try again"), href: new_import_path(type: "StatementImport"), variant: "secondary", full_width: true) %>

    <% elsif import.complete? %>
      <div class="mx-auto bg-success/10 h-8 w-8 rounded-full flex items-center justify-center">
        <%= icon "check", class: "text-success" %>
      </div>
      <div class="text-center space-y-2">
        <h1 class="font-medium text-primary text-center text-3xl"><%= t("imports.statement_import.complete_title", default: "Statement imported") %></h1>
        <p class="text-sm text-secondary"><%= t("imports.statement_import.complete_description", default: "Accounts, balances, and transactions from this statement have been applied.") %></p>
      </div>
      <%= render DS::Link.new(text: t("imports.pdf_import.back_to_imports", default: "Back to imports"), href: imports_path, variant: "primary", full_width: true) %>

    <% else %>
      <div class="text-center space-y-2">
        <h1 class="font-medium text-primary text-center text-3xl"><%= t("imports.statement_import.review_title", default: "Review statement import") %></h1>
        <p class="text-sm text-secondary"><%= t("imports.statement_import.review_description", default: "Confirm where each detected statement account should be imported before publishing.") %></p>
      </div>

      <div class="bg-container border border-primary rounded-xl p-4 space-y-3">
        <div class="grid grid-cols-2 gap-3 text-sm">
          <div>
            <p class="text-secondary"><%= t("imports.statement_import.provider", default: "Provider") %></p>
            <p class="text-primary font-medium"><%= import.provider.upcase %></p>
          </div>
          <div>
            <p class="text-secondary"><%= t("imports.statement_import.file_type", default: "File type") %></p>
            <p class="text-primary font-medium"><%= import.file_type.upcase %></p>
          </div>
        </div>
      </div>

      <div class="space-y-4" data-controller="statement-review-form" data-statement-review-form-clean-value="<%= import.review_complete? %>">
        <%= form_with model: import, url: import_path(import), scope: :statement_import, method: :patch, class: "space-y-4", data: { action: "input->statement-review-form#markDirty change->statement-review-form#markDirty" } do |form| %>
          <% import.extracted_accounts.each_with_index do |account_payload, index| %>
            <% review = account_payload["review"] || {} %>
            <% selected_action = review["action"].presence || (account_payload["matched_account_id"].present? ? "match" : "create") %>
            <div class="bg-container border border-primary rounded-xl p-4 space-y-4" data-controller="statement-review">
              <div>
                <h2 class="font-medium text-primary"><%= account_payload["name"] %></h2>
                <p class="text-sm text-secondary">
                  <%= account_payload["transactions"].size %> transactions
                  <% if account_payload["trades"].present? %>
                    · <%= account_payload["trades"].size %> trades
                  <% end %>
                  <% if account_payload["positions"].present? %>
                    · <%= account_payload["positions"].size %> positions
                  <% end %>
                  ·
                  <%= account_payload["currency"] %>
                  <% if account_payload["closing_balance"].present? %>
                    · balance <%= account_payload["closing_balance"] %>
                  <% end %>
                  <% if account_payload["cash_balance"].present? %>
                    · cash <%= account_payload["cash_balance"] %>
                  <% end %>
                </p>
              </div>

              <% if account_payload["trades"].present? || account_payload["positions"].present? %>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
                  <% if account_payload["trades"].present? %>
                    <div class="bg-container-inset rounded-lg p-3">
                      <p class="text-secondary mb-1"><%= t("imports.statement_import.trades", default: "Trades") %></p>
                      <p class="text-primary font-medium">
                        <%= account_payload["trades"].first(3).map { |trade| [ trade["activity_label"], trade["qty"], trade["ticker"] ].compact.join(" ") }.join(", ") %>
                      </p>
                    </div>
                  <% end %>
                  <% if account_payload["positions"].present? %>
                    <div class="bg-container-inset rounded-lg p-3">
                      <p class="text-secondary mb-1"><%= t("imports.statement_import.positions", default: "Positions") %></p>
                      <p class="text-primary font-medium">
                        <%= account_payload["positions"].first(3).map { |position| [ position["qty"], position["ticker"] ].compact.join(" ") }.join(", ") %>
                      </p>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <%= hidden_field_tag "statement_import[accounts][#{index}][source_id]", account_payload["source_id"] %>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <label class="space-y-1">
                  <span class="text-sm text-secondary"><%= t("imports.statement_import.action", default: "Action") %></span>
                  <%= select_tag "statement_import[accounts][#{index}][action]",
                        options_for_select([[ "Create account", "create" ], [ "Use existing account", "match" ]], selected_action),
                        class: "form-field__input",
                        data: { statement_review_target: "action", action: "change->statement-review#update" } %>
                </label>
                <label class="space-y-1 <%= "invisible" if selected_action == "create" %>" aria-hidden="<%= selected_action == "create" %>" data-statement-review-target="existingAccountField">
                  <span class="text-sm text-secondary"><%= t("imports.statement_import.existing_account", default: "Existing account") %></span>
                  <%= select_tag "statement_import[accounts][#{index}][account_id]",
                        options_for_select(accessible_accounts.visible_manual.alphabetically.map { |a| [ a.name, a.id ] }, review["account_id"] || account_payload["matched_account_id"]),
                        include_blank: "Select account",
                        class: "form-field__input",
                        disabled: selected_action == "create",
                        data: { statement_review_target: "existingAccountSelect" } %>
                </label>
                <label class="space-y-1">
                  <span class="text-sm text-secondary"><%= t("imports.statement_import.account_name", default: "Account name") %></span>
                  <%= text_field_tag "statement_import[accounts][#{index}][account_name]", review["account_name"].presence || account_payload["name"], class: "form-field__input", autocomplete: "off" %>
                </label>
                <label class="space-y-1">
                  <span class="text-sm text-secondary"><%= t("imports.statement_import.account_type", default: "Account type") %></span>
                  <%= select_tag "statement_import[accounts][#{index}][account_type]",
                        options_for_select(Accountable::TYPES.map { |type| [ type.titleize, type ] }, review["account_type"].presence || account_payload["account_type"]),
                        class: "form-field__input" %>
                </label>
                <%= hidden_field_tag "statement_import[accounts][#{index}][account_subtype]", review["account_subtype"].presence || account_payload["subtype"] %>
                <%= hidden_field_tag "statement_import[accounts][#{index}][currency]", review["currency"].presence || account_payload["currency"].presence || Current.family.currency %>
              </div>
            </div>
          <% end %>

          <%= form.submit t("imports.statement_import.save_review", default: "Save review"),
                class: class_names(
                  "w-full font-medium text-sm px-3 py-2 rounded-lg",
                  import.review_complete? ? "text-primary bg-surface-inset hover:bg-surface-inset-hover" : "text-inverse bg-inverse hover:bg-inverse-hover"
                ),
                data: { statement_review_form_target: "saveButton" } %>
        <% end %>

        <% if import.publishable? %>
          <%= button_to t("imports.statement_import.publish", default: "Publish statement import"),
                publish_import_path(import),
                method: :post,
                class: "w-full font-medium text-sm px-3 py-2 rounded-lg text-inverse bg-inverse hover:bg-inverse-hover",
                data: { statement_review_form_target: "publishButton" } %>
        <% else %>
          <p class="text-center text-sm text-secondary"><%= t("imports.statement_import.save_before_publish", default: "Save review decisions before publishing.") %></p>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
